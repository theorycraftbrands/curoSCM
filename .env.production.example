# CuroSCM Production Environment
# Copy to .env on the server: cp .env.production.example .env

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=curoscm

# ============================================================================
# JWT — Generate with: openssl rand -base64 32
# Must be at least 32 characters. Same key used by all Supabase services.
# ============================================================================
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY=3600

# ============================================================================
# SUPABASE KEYS — Generate these from the JWT_SECRET
# Use https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or: node -e "const jwt=require('jsonwebtoken');console.log(jwt.sign({role:'anon',iss:'supabase',iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+315360000},process.env.JWT_SECRET))"
# ============================================================================
ANON_KEY=GENERATE_FROM_JWT_SECRET
SERVICE_ROLE_KEY=GENERATE_FROM_JWT_SECRET

# ============================================================================
# URLS
# ============================================================================
# The external URL where the Supabase API is accessible (via Caddy reverse proxy)
API_EXTERNAL_URL=http://127.0.0.1:8443
# The URL of your Next.js frontend (on Vercel)
SITE_URL=https://curoscm.vercel.app
# Allowed redirect URLs (comma-separated)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000

# ============================================================================
# EMAIL (optional — auto-confirm is enabled by default)
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@curoscm.com
SMTP_SENDER_NAME=CuroSCM

# ============================================================================
# REALTIME
# ============================================================================
SECRET_KEY_BASE=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING_FOR_REALTIME_ENCRYPTION_KEY
